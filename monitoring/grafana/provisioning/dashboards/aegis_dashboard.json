{
  "annotations": { "list": [] },
  "description": "Aegis-Finance — Real-time Loan Risk ML Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [

    {
      "id": 1,
      "title": "🛡️ API Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN ❌" }, "1": { "text": "ONLINE ✅" } }, "type": "value" }
          ]
        }
      },
      "targets": [{
        "expr": "up{job=\"aegis-finance-api\"}",
        "legendFormat": "API Status",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 2,
      "title": "📊 Total Predictions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(http_requests_total{handler=\"/api/predict\"})",
        "legendFormat": "Total",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 3,
      "title": "⚡ Avg Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red",    "value": 200 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rate(http_request_duration_seconds_sum{handler=\"/api/predict\"}[5m]) / rate(http_request_duration_seconds_count{handler=\"/api/predict\"}[5m]) * 1000",
        "legendFormat": "Avg Latency",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 4,
      "title": "🚨 Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
        "legendFormat": "Error %",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 5,
      "title": "📈 Request Rate — Predictions Per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=\"/api/predict\"}[1m]))",
          "legendFormat": "Predictions/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=\"/api/predict\", status_code=~\"5..\"}[1m]))",
          "legendFormat": "Errors/sec",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 6,
      "title": "⏱️ Prediction Latency Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLA Limit (200ms)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=\"/api/predict\"}[5m])) * 1000",
          "legendFormat": "p50 Latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/api/predict\"}[5m])) * 1000",
          "legendFormat": "p95 Latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/api/predict\"}[5m])) * 1000",
          "legendFormat": "p99 Latency",
          "refId": "C"
        },
        {
          "expr": "vector(200)",
          "legendFormat": "SLA Limit (200ms)",
          "refId": "D"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 7,
      "title": "🏦 Risk Decision Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=\"/api/predict\", status_code=\"200\"}) by (status_code)",
          "legendFormat": "Predictions Served",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 8,
      "title": "💻 CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rate(process_cpu_seconds_total{job=\"aegis-finance-api\"}[1m]) * 100",
        "legendFormat": "CPU %",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 9,
      "title": "🧠 Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [{
        "expr": "process_resident_memory_bytes{job=\"aegis-finance-api\"} / 1024 / 1024",
        "legendFormat": "Memory MB",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 10,
      "title": "🔍 HTTP Status Codes Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=\"200\"}[1m]))",
          "legendFormat": "200 OK",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"422\"}[1m]))",
          "legendFormat": "422 Validation Error",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"500\"}[1m]))",
          "legendFormat": "500 Server Error",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 11,
      "title": "📊 Requests by Endpoint",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum by (handler) (http_requests_total)",
        "legendFormat": "{{handler}}",
        "refId": "A"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }

  ],

  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["aegis-finance", "mlops", "loan-risk", "monitoring"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "🛡️ Aegis-Finance — Risk Gateway Monitor",
  "uid": "aegis-finance-monitor",
  "version": 1
}
